{{- $pages := where site.RegularPages "Section" "posts" -}}
[
  {{- range $i, $p := $pages }}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "date": {{ $p.Date.Format "2006年1月2日" | jsonify }},
    "summary": {{ ($p.Description | default ($p.Summary | plainify | truncate 150)) | jsonify }}
  }
  {{- end }}
]
